using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace VoidLauncherUI
{
    public partial class Form1 : Form
    {
        public Form1()
        {
            InitializeComponent();
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            // Initial load config
            LoadSettingsPage("System Settings");
        }

        private void MenuButton_Click(object sender, EventArgs e)
        {
            Button btn = sender as Button;
            if (btn != null)
            {
                LoadSettingsPage(btn.Tag.ToString());
            }
        }

        private void LoadSettingsPage(string pageName)
        {
            panelContent.Controls.Clear();
            
            Label title = new Label();
            title.Text = pageName;
            title.Font = new Font("Segoe UI Semibold", 16F, FontStyle.Regular, GraphicsUnit.Point, ((byte)(0)));
            title.ForeColor = Color.White;
            title.Location = new Point(20, 20);
            title.AutoSize = true;
            panelContent.Controls.Add(title);

            // Generate fake controls depending on the page
            if (pageName == "System Settings")
            {
                AddSwitch("Enable Hardware Acceleration", 70);
                AddSwitch("Launch on Startup", 120);
                AddDropdown("Performance Mode", 170, new string[] { "Low", "Medium", "High" });
            }
            else if (pageName == "Personalities")
            {
                AddSwitch("Dark Mode", 70);
                AddSwitch("Enable Animations", 120);
            }
        }

        private void AddSwitch(string text, int yPos)
        {
            CheckBox chk = new CheckBox();
            chk.Text = text;
            chk.ForeColor = Color.White;
            chk.Font = new Font("Segoe UI", 10F);
            chk.Location = new Point(20, yPos);
            chk.AutoSize = true;
            // Native CheckBox acting as a toggle; you can style it further 
            // visually in WinForms or use a custom painted control.
            panelContent.Controls.Add(chk);
        }

        private void AddDropdown(string text, int yPos, string[] options)
        {
            Label lbl = new Label();
            lbl.Text = text;
            lbl.ForeColor = Color.White;
            lbl.Font = new Font("Segoe UI", 10F);
            lbl.Location = new Point(20, yPos);
            lbl.AutoSize = true;
            panelContent.Controls.Add(lbl);

            ComboBox dropDown = new ComboBox();
            dropDown.Items.AddRange(options);
            dropDown.DropDownStyle = ComboBoxStyle.DropDownList;
            dropDown.Location = new Point(250, yPos - 2);
            dropDown.BackColor = Color.FromArgb(45, 25, 65);
            dropDown.ForeColor = Color.White;
            dropDown.FlatStyle = FlatStyle.Flat;
            if (options.Length > 0) dropDown.SelectedIndex = 1; // Default to Medium
            panelContent.Controls.Add(dropDown);
        }
    }
}
